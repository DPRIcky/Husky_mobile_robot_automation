<?xml version="1.0" ?>
<model>
  <name>aruco_marker_0</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Static upright panel displaying ArUco DICT_4X4_50 marker ID 0.
    Face dimensions: 0.4 m x 0.4 m.  Panel thickness: 0.01 m.
    Default spawn pose: x=3.0 y=0.0 z=0.8 (panel centre height 0.8 m).
    Use scripts/spawn_aruco_marker.py to spawn into a running Gazebo world.
  </description>
</model>
